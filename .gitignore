# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Windows test logs
tools/logs/*
!tools/logs/.gitkeep

# Xcode user data & build artifacts
**/xcuserdata/
**/project.xcworkspace/

# tvOS build artifacts
tvos/**/build/
tvos/**/simbuild/

# Supabase CLI temp files
supabase/.temp/

# Claude Code local settings
.claude/settings.local.json
