<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>fr.unimaru.unistream</id>

  <name>UniStream</name>
  <summary>IPTV streaming application for Live TV, VOD and Series</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>LicenseRef-proprietary</project_license>

  <developer id="fr.unimaru">
    <name>UniMaru</name>
  </developer>

  <description>
    <p>
      UniStream is a multiplatform IPTV streaming application built with Flutter.
      Connect to your Xtream Codes provider to watch live TV channels, video on demand,
      and TV series with a modern, responsive interface.
    </p>
    <p>Features:</p>
    <ul>
      <li>Live TV with EPG guide, catch-up replay, and quick channel zapping</li>
      <li>Video on Demand with detail pages, resume playback, and ratings</li>
      <li>TV Series with season/episode navigation and auto-play next</li>
      <li>Multiple profiles with optional PIN protection</li>
      <li>Cross-device sync via cloud (favorites, watchlist, watch progress)</li>
      <li>Dark and light themes</li>
      <li>Keyboard shortcuts for desktop</li>
      <li>French and English localization</li>
    </ul>
  </description>

  <url type="homepage">https://github.com/unimaru69/unistream</url>
  <url type="bugtracker">https://github.com/unimaru69/unistream/issues</url>

  <launchable type="desktop-id">fr.unimaru.unistream.desktop</launchable>

  <provides>
    <binary>unistream</binary>
  </provides>

  <content_rating type="oars-1.1" />

  <releases>
    <release version="1.0.0" date="2026-04-06">
      <description>
        <p>Initial release with Live TV, VOD, Series, EPG guide, multi-profile support, and cross-device sync.</p>
      </description>
    </release>
  </releases>

  <categories>
    <category>AudioVideo</category>
    <category>Video</category>
    <category>Player</category>
  </categories>

  <keywords>
    <keyword>iptv</keyword>
    <keyword>streaming</keyword>
    <keyword>tv</keyword>
    <keyword>vod</keyword>
    <keyword>series</keyword>
    <keyword>epg</keyword>
  </keywords>

